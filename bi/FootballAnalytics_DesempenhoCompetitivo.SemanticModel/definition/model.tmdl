model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["FactMatch","FactTeamMatch","FactPlayerMatch","DimScope","DimDate","DimTeam","DimPlayer","Medidas"]

annotation PBI_ProTooling = ["DevMode"]

ref table FactMatch
ref table FactTeamMatch
ref table FactPlayerMatch
ref table DimScope
ref table DimDate
ref table DimTeam
ref table DimPlayer
ref table Medidas

ref cultureInfo pt-BR
