{
  "name": "Football Analytics",
  "dataColors": [
    "#00513B",
    "#8BD6B6",
    "#111C2D",
    "#4C6FA8",
    "#C08A3E",
    "#5D8072",
    "#8A6D18",
    "#D8E3FB"
  ],
  "foreground": "#111C2D",
  "foregroundNeutralSecondary": "#57657A",
  "foregroundNeutralTertiary": "#93A0B4",
  "background": "#FFFFFF",
  "backgroundLight": "#F4F8F5",
  "backgroundNeutral": "#D8E3FB",
  "tableAccent": "#00513B",
  "good": "#16825D",
  "neutral": "#C08A3E",
  "bad": "#C75555",
  "maximum": "#003526",
  "center": "#8BD6B6",
  "minimum": "#EAF5EF",
  "null": "#93A0B4",
  "textClasses": {
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "color": "#003526"
    },
    "title": {
      "fontFace": "Segoe UI Semibold",
      "color": "#111C2D"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "color": "#111C2D"
    },
    "label": {
      "fontFace": "Segoe UI",
      "color": "#57657A"
    }
  },
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F4F8F5"
              }
            },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#E7EFEA"
              }
            }
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D8E3FB"
              }
            },
            "radius": 12
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#111C2D"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12,
            "alignment": "left",
            "titleWrap": true
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#57657A"
              }
            },
            "titleColor": {
              "solid": {
                "color": "#111C2D"
              }
            },
            "gridlineStyle": "dotted"
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#57657A"
              }
            },
            "titleColor": {
              "solid": {
                "color": "#111C2D"
              }
            },
            "gridlineColor": {
              "solid": {
                "color": "#D8E3FB"
              }
            },
            "gridlineStyle": "dotted"
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "background": [
          {
            "show": false
          }
        ],
        "border": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "layout": [
          {
            "$id": "default",
            "backgroundShow": true,
            "paddingUniform": 10,
            "cellPadding": 8
          }
        ],
        "value": [
          {
            "$id": "default",
            "fontFamily": "Segoe UI Semibold",
            "fontColor": {
              "solid": {
                "color": "#003526"
              }
            }
          }
        ],
        "label": [
          {
            "$id": "default",
            "position": "belowValue",
            "fontColor": {
              "solid": {
                "color": "#57657A"
              }
            }
          }
        ],
        "outline": [
          {
            "$id": "default",
            "lineColor": {
              "solid": {
                "color": "#D8E3FB"
              }
            }
          }
        ],
        "shapeCustomRectangle": [
          {
            "$id": "default",
            "tileShape": "rectangleRoundedByPixel",
            "rectangleRoundedCurve": 12
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#57657A"
              }
            },
            "textSize": 10
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#111C2D"
              }
            },
            "textSize": 11,
            "padding": 4
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#003526"
              }
            },
            "backColor": {
              "solid": {
                "color": "#F4F8F5"
              }
            },
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColorPrimary": {
              "solid": {
                "color": "#111C2D"
              }
            },
            "backColorPrimary": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "backColorSecondary": {
              "solid": {
                "color": "#F8FBF9"
              }
            }
          }
        ],
        "grid": [
          {
            "gridColor": {
              "solid": {
                "color": "#D8E3FB"
              }
            },
            "rowPadding": 7
          }
        ],
        "total": [
          {
            "fontColor": {
              "solid": {
                "color": "#003526"
              }
            },
            "backColor": {
              "solid": {
                "color": "#EAF5EF"
              }
            }
          }
        ]
      }
    }
  }
}
