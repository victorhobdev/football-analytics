# Sanitized local environment template.
# Copy values into the local .env or the host secret manager; do not commit real secrets.

ENVIRONMENT=local

# BFF
BFF_APP_NAME=football-analytics-bff
BFF_LOG_LEVEL=INFO
BFF_EXPOSE_API_DOCS=true
BFF_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
BFF_CORS_ALLOW_CREDENTIALS=false
BFF_CORS_ALLOW_METHODS=GET,HEAD,OPTIONS
BFF_CORS_ALLOW_HEADERS=Accept,Accept-Language,Authorization,Content-Language,Content-Type,X-Request-Id
BFF_RATE_LIMIT_ENABLED=true
BFF_RATE_LIMIT_DEFAULT_PER_MINUTE=300
BFF_RATE_LIMIT_SEARCH_PER_MINUTE=60
BFF_RATE_LIMIT_HEALTH_PER_MINUTE=600
BFF_RATE_LIMIT_WINDOW_SECONDS=60
BFF_RATE_LIMIT_TRUST_PROXY_HEADERS=false

# Frontend public value. Never put tokens in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_BFF_BASE_URL=http://localhost:8000

# Postgres
POSTGRES_USER=football
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=football_dw
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
FOOTBALL_PG_DSN=postgresql://football:change_me_postgres_password@localhost:5432/football_dw
DATABASE_URL=postgresql://football:change_me_postgres_password@localhost:5432/football_dw

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_root_password
MINIO_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret_key

# Airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://football:change_me_postgres_password@postgres:5432/football_dw
AIRFLOW__CORE__FERNET_KEY=change_me_generated_fernet_key
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_webserver_secret_key
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_admin_password
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Providers
ACTIVE_PROVIDER=sportmonks
APIFOOTBALL_API_KEY=change_me_or_leave_blank
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io
APIFOOTBALL_DEFAULT_LEAGUE_ID=71
APIFOOTBALL_DEFAULT_SEASON=2024
API_KEY_SPORTMONKS=change_me_or_leave_blank
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football
SPORTMONKS_DEFAULT_LEAGUE_ID=648
SPORTMONKS_DEFAULT_SEASON=2024
INGEST_FIXTURES_REQUESTS_PER_MINUTE=0
INGEST_STATISTICS_REQUESTS_PER_MINUTE=0
INGEST_EVENTS_REQUESTS_PER_MINUTE=0
